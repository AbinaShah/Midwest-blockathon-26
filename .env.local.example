# ProofFund — Frontend environment (copy to .env.local)

# REQUIRED: Deployed contract address (after: npx hardhat run scripts/deploy.js --network sepolia)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# REQUIRED for Pinata: Campaign metadata + milestone proofs on IPFS
# Get JWT at https://app.pinata.cloud/ — Developers → API Keys → New Key
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_here

# REQUIRED for XRPL: Treasury address for XRP/RLUSD donations
# Create XRPL testnet account at https://xrpl.org/xrp-testnet-faucet.html
NEXT_PUBLIC_XRPL_TREASURY_ADDRESS=rYourXrplAddressHere

# XRPL network: testnet (default) or devnet
NEXT_PUBLIC_XRPL_NETWORK=testnet

# XRPL-native mode: server-side secret for milestone payouts (Release)
# Must match NEXT_PUBLIC_XRPL_TREASURY_ADDRESS
# XRPL_TREASURY_SECRET=s...

# Optional
NEXT_PUBLIC_ALCHEMY_RPC_URL=
NEXT_PUBLIC_AI_API_URL=http://localhost:8000
